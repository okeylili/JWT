NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/secureauth?schema=public
REDIS_URL=redis://redis:6379
JWT_ACCESS_SECRET=replace_with_at_least_32_characters_access_secret
JWT_REFRESH_SECRET=replace_with_at_least_32_characters_refresh_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=14
BCRYPT_ROUNDS=12
CSRF_COOKIE_NAME=_csrf
